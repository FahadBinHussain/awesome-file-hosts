{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/awesome-file-hosts/adjacent.schema.json",
  "title": "awesome-file-hosts adjacent datasets",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "kind",
      "name",
      "url",
      "summary",
      "account",
      "developer",
      "content",
      "security",
      "tags",
      "sources",
      "profile"
    ],
    "allOf": [
      { "$ref": "#/$defs/sharedVerifiedFields" },
      {
        "oneOf": [
          {
            "properties": {
              "kind": { "const": "alternative" },
              "profile": { "$ref": "#/$defs/alternativeProfile" }
            }
          },
          {
            "properties": {
              "kind": { "const": "mirror_uploader" },
              "profile": { "$ref": "#/$defs/mirrorProfile" }
            }
          },
          {
            "properties": {
              "kind": { "const": "cloud_migration" },
              "profile": { "$ref": "#/$defs/cloudMigrationProfile" }
            }
          }
        ]
      }
    ]
  },
  "$defs": {
    "sourceRefs": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "minItems": 1
    },
    "limitField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "notes"],
      "properties": {
        "value": { "type": ["number", "null"] },
        "unit": { "type": ["string", "null"] },
        "notes": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/sourceRefs" }
      }
    },
    "textField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "notes"],
      "properties": {
        "value": { "type": ["string", "null"] },
        "notes": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/sourceRefs" }
      }
    },
    "booleanField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "notes"],
      "properties": {
        "value": { "type": ["boolean", "null"] },
        "notes": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/sourceRefs" }
      }
    },
    "sharedVerifiedFields": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "summary": { "type": "string", "minLength": 1 },
        "account": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "benefits"],
          "properties": {
            "required": { "type": ["boolean", "null"] },
            "benefits": { "type": "string" },
            "source_refs": { "$ref": "#/$defs/sourceRefs" }
          }
        },
        "developer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["api_available", "api_docs_url", "cli_friendly", "cli_example", "notes"],
          "properties": {
            "api_available": { "type": "boolean" },
            "api_docs_url": { "type": ["string", "null"], "format": "uri" },
            "cli_friendly": { "type": "boolean" },
            "cli_example": { "type": ["string", "null"] },
            "notes": { "type": "string" },
            "source_refs": { "$ref": "#/$defs/sourceRefs" }
          }
        },
        "content": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed_file_types"],
          "properties": {
            "allowed_file_types": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "notes"],
              "properties": {
                "mode": { "type": "string", "minLength": 1 },
                "notes": { "type": "string" },
                "source_refs": { "$ref": "#/$defs/sourceRefs" }
              }
            },
            "public_sharing": {
              "$ref": "#/$defs/booleanField"
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": ["https_only", "e2ee", "server_side_encryption", "notes"],
          "properties": {
            "https_only": { "type": "boolean" },
            "e2ee": { "type": "boolean" },
            "server_side_encryption": { "type": ["boolean", "null"] },
            "notes": { "type": "string" },
            "source_refs": { "$ref": "#/$defs/sourceRefs" }
          }
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "url", "retrieved_at", "notes"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "format": "uri" },
              "retrieved_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              "notes": { "type": "string" }
            }
          }
        },
        "profile": { "type": "object" }
      }
    },
    "alternativeProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_use",
        "sharing_surface",
        "max_file_size",
        "persistence_model",
        "storage_model",
        "bandwidth_model"
      ],
      "properties": {
        "primary_use": { "$ref": "#/$defs/textField" },
        "sharing_surface": { "$ref": "#/$defs/textField" },
        "max_file_size": { "$ref": "#/$defs/limitField" },
        "persistence_model": { "$ref": "#/$defs/textField" },
        "storage_model": { "$ref": "#/$defs/textField" },
        "bandwidth_model": { "$ref": "#/$defs/textField" }
      }
    },
    "mirrorProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_file_size",
        "guest_uploads",
        "remote_import",
        "torrent_import",
        "stores_files_itself",
        "retention_model",
        "downstream_dependency"
      ],
      "properties": {
        "max_file_size": { "$ref": "#/$defs/limitField" },
        "guest_uploads": { "$ref": "#/$defs/booleanField" },
        "remote_import": { "$ref": "#/$defs/booleanField" },
        "torrent_import": { "$ref": "#/$defs/booleanField" },
        "stores_files_itself": { "$ref": "#/$defs/booleanField" },
        "retention_model": { "$ref": "#/$defs/textField" },
        "downstream_dependency": { "$ref": "#/$defs/textField" }
      }
    },
    "cloudMigrationProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_modes",
        "execution_model",
        "item_limit",
        "included_storage",
        "scheduled_runs",
        "provider_dependency",
        "bandwidth_model"
      ],
      "properties": {
        "workflow_modes": { "$ref": "#/$defs/textField" },
        "execution_model": { "$ref": "#/$defs/textField" },
        "item_limit": { "$ref": "#/$defs/limitField" },
        "included_storage": { "$ref": "#/$defs/limitField" },
        "scheduled_runs": { "$ref": "#/$defs/booleanField" },
        "provider_dependency": { "$ref": "#/$defs/textField" },
        "bandwidth_model": { "$ref": "#/$defs/textField" }
      }
    }
  }
}
