{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/awesome-file-hosts/hosts.schema.json",
  "title": "awesome-file-hosts dataset",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "name",
      "url",
      "summary",
      "limits",
      "account",
      "developer",
      "content",
      "security",
      "tags",
      "sources"
    ],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1
      },
      "url": {
        "type": "string",
        "format": "uri"
      },
      "summary": {
        "type": "string",
        "minLength": 1
      },
      "limits": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "max_file_size",
          "retention",
          "storage",
          "bandwidth"
        ],
        "properties": {
          "max_file_size": {
            "$ref": "#/$defs/limitField"
          },
          "retention": {
            "$ref": "#/$defs/limitField"
          },
          "storage": {
            "$ref": "#/$defs/limitField"
          },
          "bandwidth": {
            "$ref": "#/$defs/limitField"
          }
        }
      },
      "account": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "required",
          "benefits"
        ],
        "properties": {
          "required": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "benefits": {
            "type": "string"
          },
          "source_refs": {
            "$ref": "#/$defs/sourceRefList"
          }
        }
      },
      "developer": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "api_available",
          "api_docs_url",
          "cli_friendly",
          "cli_example",
          "notes"
        ],
        "properties": {
          "api_available": {
            "type": "boolean"
          },
          "api_docs_url": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "cli_friendly": {
            "type": "boolean"
          },
          "cli_example": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": "string"
          },
          "source_refs": {
            "$ref": "#/$defs/sourceRefList"
          }
        }
      },
      "content": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "allowed_file_types"
        ],
        "properties": {
          "allowed_file_types": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mode",
              "notes"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string"
              },
              "source_refs": {
                "$ref": "#/$defs/sourceRefList"
              }
            }
          }
        }
      },
      "security": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "https_only",
          "e2ee",
          "server_side_encryption",
          "notes"
        ],
        "properties": {
          "https_only": {
            "type": "boolean"
          },
          "e2ee": {
            "type": "boolean"
          },
          "server_side_encryption": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "notes": {
            "type": "string"
          },
          "source_refs": {
            "$ref": "#/$defs/sourceRefList"
          }
        }
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        },
        "uniqueItems": true
      },
      "sources": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "label",
            "url",
            "retrieved_at",
            "notes"
          ],
          "properties": {
            "label": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "retrieved_at": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "limitField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit",
        "notes"
      ],
      "properties": {
        "value": {
          "type": [
            "number",
            "integer",
            "null"
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        },
        "source_refs": {
          "$ref": "#/$defs/sourceRefList"
        }
      }
    },
    "sourceRefList": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
